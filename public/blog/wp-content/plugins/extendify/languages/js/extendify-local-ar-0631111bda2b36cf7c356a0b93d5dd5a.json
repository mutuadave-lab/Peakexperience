627\u0644\u0646\u0642\u0631 \u0639\u0644\u064a\u0647."],"View the Inserted Pattern":["\u0639\u0631\u0636 \u0627\u0644\u0646\u0645\u0637 \u0627\u0644\u0645\u064f\u062f\u0631\u062c"],"The selected pattern has been inserted into the page.":["\u062a\u0645 \u0625\u062f\u0631\u0627\u062c \u0627\u0644\u0646\u0645\u0637 \u0627\u0644\u0645\u062d\u062f\u062f \u0641\u064a \u0627\u0644\u0635\u0641\u062d\u0629."],"Add a Block":["\u0625\u0636\u0627\u0641\u0629 \u0645\u0643\u0648\u0651\u0646"],"Click the plus to open the block inserter.":["\u0627\u0646\u0642\u0631 \u0639\u0644\u0649 \u0639\u0644\u0627\u0645\u0629 \u0627\u0644\u0627\u0636\u0627\u0641\u0629 \u0644\u0641\u062a\u062d \u0623\u062f\u0627\u0629 \u0625\u062f\u0631\u0627\u062c \u0627\u0644\u0645\u0643\u0648\u0651\u0650\u0646\u0627\u062a"],"Block Inserter":["\u0623\u062f\u0627\u0629 \u0625\u062f\u0631\u0627\u062c \u0627\u0644\u0645\u0643\u0648\u0651\u0646\u0627\u062a"],"Add a block by clicking or dragging it onto the page.":["\u0623\u0636\u0641 \u0645\u0643\u0648\u0651\u0646\u064b\u0627 \u0628\u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u064a\u0647 \u0623\u0648 \u0633\u062d\u0628\u0647 \u0625\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629."],"Page Title":["\u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0635\u0641\u062d\u0629"],"Edit the page title by clicking it. Note: The title may or may not show up on the published page, depending on the page template used.":["\u062d\u0631\u0631 \u0639\u0646\u0648\u0627\u0646 \u0627\u0644\u0635\u0641\u062d\u0629 \u0628\u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u064a\u0647. \u0645\u0644\u0627\u062d\u0638\u0629: \u0642\u062f \u064a\u0638\u0647\u0631 \u0627\u0644\u0639\u0646\u0648\u0627\u0646 \u0623\u0648 \u0644\u0627 \u064a\u0638\u0647\u0631 \u0641\u064a \u0627\u0644\u0635\u0641\u062d\u0629 \u0627\u0644\u0645\u0646\u0634\u0648\u0631\u0629\u060c \u062d\u0633\u0628 \u0627\u0644\u0642\u0627\u0644\u0628 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645."],"Blocks":["\u0645\u0643\u0648\u0651\u0646\u0627\u062a"],"Each block will show up on the page and can be edited by clicking on it.":["\u0633\u064a\u0638\u0647\u0631 \u0643\u0644 \u0645\u0643\u0648\u0651\u0646 \u0639\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629 \u0648\u064a\u0645\u0643\u0646 \u062a\u062d\u0631\u064a\u0631\u0647 \u0628\u0627\u0644\u0646\u0642\u0631 \u0639\u0644\u064a\u0647."],"This is a sample paragraph block. It can be several sentences long and will span multiple rows. You can add as many blocks as you'd like to the page.":["\u0647\u0630\u0627 \u0645\u062b\u0627\u0644 \u0639\u0644\u0649 \u0645\u0643\u0648\u0651\u0646 \u0641\u0642\u0631\u0629. \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u0643\u0648\u0646 \u0637\u0648\u064a\u0644\u0627\u064b \u0644\u0639\u062f\u0629 \u062c\u0645\u0644 \u0648\u064a\u0645\u062a\u062f \u0639\u0628\u0631 \u0639\u062f\u0629 \u0635\u0641\u0648\u0641. \u064a\u0645\u0643\u0646\u0643 \u0625\u0636\u0627\u0641\u0629 \u0639\u062f\u062f \u063a\u064a\u0631 \u0645\u062d\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u0643\u0648\u0651\u0646\u0627\u062a \u0625\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629 \u0643\u0645\u0627 \u062a\u0634\u0627\u0621."],"Page and Block Settings":["\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0635\u0641\u062d\u0629 \u0648\u0627\u0644\u0645\u0643\u0648\u0650\u0651\u0646"],"Select either page or block to change the settings for the entire page or the block that is selected.":["\u0627\u062e\u062a\u0631 \u0625\u0645\u0627 \u0627\u0644\u0635\u0641\u062d\u0629 \u0623\u0648 \u0627\u0644\u0645\u0643\u0648\u0651\u0646 \u0644\u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0644\u0644\u0635\u0641\u062d\u0629 \u0628\u0623\u0643\u0645\u0644\u0647\u0627 \u0623\u0648 \u0644\u0644\u0645\u0643\u0648\u0651\u0646 \u0627\u0644\u0645\u062d\u062f\u062f."],"Preview":["\u0645\u0639\u0627\u064a\u0646\u0629"],"Click preview to view how your changes look on the front end of your site.":["\u0627\u0646\u0642\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u0639\u0627\u064a\u0646\u0629 \u0644\u0645\u0634\u0627\u0647\u062f\u0629 \u0643\u064a\u0641 \u062a\u0628\u062f\u0648 \u062a\u063a\u064a\u064a\u0631\u0627\u062a\u0643 \u0641\u064a \u0627\u0644\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0623\u0645\u0627\u0645\u064a\u0629 \u0644\u0645\u0648\u0642\u0639\u0643."],"Publish or Save":["\u0646\u0634\u0631 \u0623\u0648 \u062d\u0641\u0638"],"Click publish or update to save the changes you have made to the page and make them live on the site.":["\u0627\u0646\u0642\u0631 \u0639\u0644\u0649 \u0646\u0634\u0631 \u0623\u0648 \u062a\u062d\u062f\u064a\u062b \u0644\u062d\u0641\u0638 \u0627\u0644\u062a\u063a\u064a\u064a\u0631\u0627\u062a \u0627\u0644\u062a\u064a \u0623\u062c\u0631\u064a\u062a\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629 \u0644\u064a\u062a\u0645 \u0646\u0634\u0631\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0642\u0639."],"Add New plugin menu":["\u0623\u0636\u0641 \u0642\u0627\u0626\u0645\u0629 \u0645\u0643\u0648\u0646 \u0625\u0636\u0627\u0641\u064a \u062c\u062f\u064a\u062f\u0629"],"Click here to access the Add Plugins page.":["\u0627\u0646\u0642\u0631 \u0647\u0646\u0627 \u0644\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0635\u0641\u062d\u0629 \u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0625\u0636\u0627\u0641\u0627\u062a."],"Search":["\u0627\u0644\u0628\u062d\u062b"],"Search for a plugin by name or functionality.":["\u0627\u0628\u062d\u062b \u0639\u0646 \u0625\u0636\u0627\u0641\u0629 \u0628\u0627\u0644\u0627\u0633\u0645 \u0623\u0648 \u0627\u0644\u0648\u0638\u064a\u0641\u0629."],"Plugin details":["\u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0625\u0636\u0627\u0641\u0629"],"See important information about each plugin.":["\u0627\u0637\u0644\u0639 \u0639\u0644\u0649 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0647\u0627\u0645\u0629 \u062d\u0648\u0644 \u0643\u0644 \u0625\u0636\u0627\u0641\u0629."],"Install now":["\u062b\u0628\u0651\u062a \u0627\u0644\u0622\u0646"],"Install the plugin. Then, press this button again to activate the plugin.":["\u0642\u0645 \u0628\u062a\u0646\u0635\u064a\u0628 \u0627\u0644\u0625\u0636\u0627\u0641\u0629. \u062b\u0645 \u0627\u0636\u063a\u0637 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0632\u0631 \u0645\u0631\u0629 \u0623\u062e\u0631\u0649 \u0644\u062a\u0641\u0639\u064a\u0644 \u0627\u0644\u0625\u0636\u0627\u0641\u0629."],"Upload Plugin":["\u0631\u0641\u0639 \u0627\u0644\u0625\u0636\u0627\u0641\u0629"],"If you have a plugin from an external source, you can upload it directly here.":["\u0625\u0630\u0627 \u0643\u0627\u0646 \u0644\u062f\u064a\u0643 \u0625\u0636\u0627\u0641\u0629 \u0645\u0646 \u0645\u0635\u062f\u0631 \u062e\u0627\u0631\u062c\u064a\u060c \u064a\u0645\u0643\u0646\u0643 \u0631\u0641\u0639\u0647\u0627 \u0645\u0628\u0627\u0634\u0631\u0629 \u0647\u0646\u0627."],"Installed Plugins menu":["\u0642\u0627\u0626\u0645\u0629 \u0627\u0644\u0625\u0636\u0627\u0641\u0627\u062a \u0627\u0644\u0645\u062b\u0628\u062a\u0629"],"Click this menu to see and manage the plugins you have installed.":["\u0627\u0646\u0642\u0631 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0644\u0639\u0631\u0636 \u0648\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0625\u0636\u0627\u0641\u0627\u062a \u0627\u0644\u0645\u062b\u0628\u062a\u0629 \u0644\u062f\u064a\u0643."],"Installed plugins":["\u0627\u0644\u0625\u0636\u0627\u0641\u0627\u062a \u0627\u0644\u0645\u0646\u0635\u0651\u0628\u0629"],"See all plugins installed on your site. This includes plugins that are active and deactivated.":["\u0639\u0631\u0636 \u062c\u0645\u064a\u0639 \u0627\u0644\u0625\u0636\u0627\u0641\u0627\u062a \u0627\u0644\u0645\u062b\u0628\u062a\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639\u0643. \u064a\u0634\u0645\u0644 \u0630\u0644\u0643 \u0627\u0644\u0625\u0636\u0627\u0641\u0627\u062a \u0627\u0644\u0646\u0634\u0637\u0629 \u0648\u0627\u0644\u0645\u0639\u0637\u0644\u0629."],"Deactivate\/activate option":["\u062a\u0639\u0637\u064a\u0644\/\u062a\u0641\u0639\u064a\u0644 \u0627\u0644\u062e\u064a\u0627\u0631"],"Under each plugin you can activate or deactivate it.":["\u062a\u062d\u062a \u0643\u0644 \u0625\u0636\u0627\u0641\u0629 \u064a\u0645\u0643\u0646\u0643 \u062a\u0641\u0639\u064a\u0644\u0647\u0627 \u0623\u0648 \u062a\u0639\u0637\u064a\u0644\u0647\u0627."],"Add another":["\u0623\u0636\u0641 \u0622\u062e\u0631"],"Click here to add another plugin to your site.":["\u0627\u0646\u0642\u0631 \u0647\u0646\u0627 \u0644\u0625\u0636\u0627\u0641\u0629 \u0625\u0636\u0627\u0641\u0629 \u0623\u062e\u0631\u0649 \u0625\u0644\u0649 \u0645\u0648\u0642\u0639\u0643."],"Tasks":["\u0645\u0647\u0627\u0645"],"Now that you've created your starter site, make it your own with these follow up tasks.":["\u0627\u0644\u0622\u0646 \u0628\u0639\u062f \u0623\u0646 \u0623\u0646\u0634\u0623\u062a \u0645\u0648\u0642\u0639\u0643 \u0627\u0644\u0645\u0628\u062f\u0626\u064a\u060c \u0627\u062c\u0639\u0644\u0647 \u062e\u0627\u0635\u064b\u0627 \u0628\u0643 \u0645\u0646 \u062e\u0644\u0627\u0644 \u062a\u0646\u0641\u064a\u0630 \u0627\u0644\u0645\u0647\u0627\u0645 \u0627\u0644\u062a\u0627\u0644\u064a\u0629."],"Easily access some of the most common items in WordPress with these quick links.":["\u0627\u0644\u0648\u0635\u0648\u0644 \u0628\u0633\u0647\u0648\u0644\u0629 \u0625\u0644\u0649 \u0628\u0639\u0636 \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u0623\u0643\u062b\u0631 \u0634\u064a\u0648\u0639\u064b\u0627 \u0641\u064a \u0648\u0648\u0631\u062f\u0628\u0631\u064a\u0633 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0647\u0630\u0647 \u0627\u0644\u0631\u0648\u0627\u0628\u0637 \u0627\u0644\u0633\u0631\u064a\u0639\u0629."],"See our personalized recommendations for you that will help you accomplish your goals.":["\u0627\u0637\u0644\u0639 \u0639\u0644\u0649 \u062a\u0648\u0635\u064a\u0627\u062a\u0646\u0627 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0627\u0644\u062a\u064a \u0633\u062a\u0633\u0627\u0