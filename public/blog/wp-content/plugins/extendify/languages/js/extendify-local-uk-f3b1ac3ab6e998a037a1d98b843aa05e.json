\u0438 \u0442\u0430 \u0441\u0442\u0432\u043e\u0440\u0438\u043c\u043e \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u0456 \u0437\u0430\u043f\u0438\u0441\u0438 \u0443 \u0432\u0438\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u0440\u043e\u0432\u0430\u0439\u0434\u0435\u0440\u0456\u0432. \u0426\u0435 \u0437\u0430\u0439\u043c\u0435 \u043b\u0438\u0448\u0435 \u043c\u0438\u0442\u044c"],"Setup complete":["\u041d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u043e"],"Your plugin accounts have been set up. Account activation may take a moment to complete.":["\u0412\u0430\u0448\u0456 \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u0456 \u0437\u0430\u043f\u0438\u0441\u0438 \u043f\u043b\u0430\u0433\u0456\u043d\u0443 \u043d\u0430\u043b\u0430\u0448\u0442\u043e\u0432\u0430\u043d\u043e. \u0410\u043a\u0442\u0438\u0432\u0430\u0446\u0456\u044f \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u0438\u0445 \u0437\u0430\u043f\u0438\u0441\u0456\u0432 \u043c\u043e\u0436\u0435 \u0437\u0430\u0439\u043d\u044f\u0442\u0438 \u0434\u0435\u044f\u043a\u0438\u0439 \u0447\u0430\u0441."],"Almost done! Let's finish setting up your plugins":["\u041c\u0430\u0439\u0436\u0435 \u0433\u043e\u0442\u043e\u0432\u043e! \u0417\u0430\u0432\u0435\u0440\u0448\u0456\u043c\u043e \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0432\u0430\u0448\u0438\u0445 \u043f\u043b\u0430\u0433\u0456\u043d\u0456\u0432"],"Term of Service":["\u0423\u043c\u043e\u0432\u0438 \u043e\u0431\u0441\u043b\u0443\u0433\u043e\u0432\u0443\u0432\u0430\u043d\u043d\u044f"],"Email address":["E-mail \u0430\u0434\u0440\u0435\u0441\u0430"],"This email will be used to create accounts with the selected plugin providers. Form protected by reCAPTCHA.":["\u0426\u044f e-mail \u0430\u0434\u0440\u0435\u0441\u0430 \u0431\u0443\u0434\u0435 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u0430 \u0434\u043b\u044f \u0441\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u044f \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u0438\u0445 \u0437\u0430\u043f\u0438\u0441\u0456\u0432 \u0443 \u0432\u0438\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u043e\u0441\u0442\u0430\u0447\u0430\u043b\u044c\u043d\u0438\u043a\u0456\u0432 \u043f\u043b\u0430\u0433\u0456\u043d\u0456\u0432. \u0424\u043e\u0440\u043c\u0443 \u0437\u0430\u0445\u0438\u0449\u0435\u043d\u043e reCAPTCHA."],"I agree to create accounts with the selected providers using my email address, and to their applicable Terms of Service.":["\u042f \u043f\u043e\u0433\u043e\u0434\u0436\u0443\u044e\u0441\u044f \u0441\u0442\u0432\u043e\u0440\u044e\u0432\u0430\u0442\u0438 \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u0456 \u0437\u0430\u043f\u0438\u0441\u0438 \u0443 \u0432\u0438\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u0440\u043e\u0432\u0430\u0439\u0434\u0435\u0440\u0456\u0432, \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0447\u0438 \u0441\u0432\u043e\u044e email-\u0430\u0434\u0440\u0435\u0441\u0443, \u0442\u0430 \u043f\u0440\u0438\u0439\u043c\u0430\u044e \u0457\u0445\u043d\u0456 \u0443\u043c\u043e\u0432\u0438 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u0430\u043d\u043d\u044f."],"I wish to receive communications about news and\/or promotions from selected providers.":["\u042f \u0431\u0430\u0436\u0430\u044e \u043e\u0442\u0440\u0438\u043c\u0443\u0432\u0430\u0442\u0438 \u0456\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0456\u044e \u043f\u0440\u043e \u043d\u043e\u0432\u0438\u043d\u0438 \u0442\u0430\/\u0430\u0431\u043e \u0430\u043a\u0446\u0456\u0457 \u0432\u0456\u0434 \u0432\u0438\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u043e\u0441\u0442\u0430\u0447\u0430\u043b\u044c\u043d\u0438\u043a\u0456\u0432."],"No thanks":["\u041d\u0456, \u0434\u044f\u043a\u0443\u044e"],"Create accounts":["\u0421\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u043e\u0431\u043b\u0456\u043a\u043e\u0432\u0456 \u0437\u0430\u043f\u0438\u0441\u0438"]}}}