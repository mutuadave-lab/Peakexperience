{"translation-revision-date":"2023-10-17 14:31:16+0000","generator":"WP-CLI\/2.12.0","source":"public\/build\/extendify-shared-a0f4a4fcde46bba78e82.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"ca","plural-forms":"nplurals=2; plural=n != 1;"},"Close":["\u0417\u0430\u0442\u0432\u043e\u0440\u0438"],"Close ToolTip":["\u0417\u0430\u0442\u0432\u043e\u0440\u0438 \u043e\u0431\u0458\u0430\u0448\u045a\u0435\u045a\u0435"],"Tooltip pointing to the edit page button":["\u0421\u0430\u0432\u0435\u0442\u043d\u0438\u043a \u043a\u043e\u0458\u0438 \u043f\u043e\u043a\u0430\u0437\u0443\u0458\u0435 \u043d\u0430 \u0434\u0443\u0433\u043c\u0435 \u0437\u0430 \u0443\u0440\u0435\u0452\u0438\u0432\u0430\u045a\u0435 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0435"],"Welcome to your new site! When you're ready, press here to edit this page.":["\u0414\u043e\u0431\u0440\u043e \u0434\u043e\u0448\u043b\u0438 \u043d\u0430 \u0432\u0430\u0448\u0435 \u043d\u043e\u0432\u043e \u0432\u0435\u0431 \u043c\u0435\u0441\u0442\u043e! \u041a\u0430\u0434\u0430 \u0431\u0443\u0434\u0435\u0442\u0435 \u0441\u043f\u0440\u0435\u043c\u043d\u0438, \u043f\u0440\u0438\u0442\u0438\u0441\u043d\u0438\u0442\u0435 \u043e\u0432\u0434\u0435 \u0434\u0430 \u0443\u0440\u0435\u0434\u0438\u0442\u0435 \u043e\u0432\u0443 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443."],"Setting up plugins for you...":["\u041f\u043e\u0434\u0435\u0448\u0430\u0432\u0430\u045a\u0435 \u0434\u043e\u0434\u0430\u0442\u0430\u043a\u0430 \u0437\u0430 \u0432\u0430\u0441..."],"Please wait while we install your plugins and create accounts with the selected providers. This should only take a moment.":["\u0421\u0430\u0447\u0435\u043a\u0430\u0458\u0442\u0435 \u0434\u043e\u043a \u0438\u043d\u0441\u0442\u0430\u043b\u0438\u0440\u0430\u043c\u043e \u0432\u0430\u0448\u0435 \u0434\u043e\u0434\u0430\u0442\u043a\u0435 \u0438 \u043a\u0440\u0435\u0438\u0440\u0430\u043c\u043e \u043d\u0430\u043b\u043e\u0433\u0435 \u043a\u043e\u0434 \u043e\u0434\u0430\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u0440\u043e\u0432\u0430\u0458\u0434\u0435\u0440\u0430. \u041e\u0432\u043e \u045b\u0435 \u0442\u0440\u0430\u0458\u0430\u0442\u0438 \u0441\u0430\u043c\u043e \u0442\u0440\u0435\u043d\u0443\u0442\u0430\u043a."],"Setup complete":["\u041f\u043e\u0441\u0442\u0430\u0432\u0459\u0430\u045a\u0435 \u0437\u0430\u0432\u0440\u0448\u0435\u043d\u043e"],"Your plugin accounts have been set up. Account activation may take a moment to complete.":["\u0412\u0430\u0448\u0438 \u043d\u0430\u043b\u043e\u0437\u0438 \u0437\u0430 \u0434\u043e\u0434\u0430\u0442\u043a\u0435 \u0441\u0443 \u043f\u043e\u0434\u0435\u0448\u0435\u043d\u0438. \u0410\u043a\u0442\u0438\u0432\u0438\u0440\u0430\u045a\u0435 \u043d\u0430\u043b\u043e\u0433\u0430 \u043c\u043e\u0436\u0435 \u043f\u043e\u0442\u0440\u0430\u0458\u0430\u0442\u0438 \u043d\u0435\u043a\u043e\u043b\u0438\u043a\u043e \u0442\u0440\u0435\u043d\u0443\u0442\u0430\u043a\u0430."],"Almost done! Let's finish setting up your plugins":["\u0421\u043a\u043e\u0440\u043e \u0433\u043e\u0442\u043e\u0432\u043e! \u0417\u0430\u0432\u0440\u0448\u0438\u043c\u043e \u043f\u043e\u0434\u0435\u0448\u0430\u0432\u0430\u045a\u0435 \u0432\u0430\u0448\u0438\u0445 \u0434\u043e\u0434\u0430\u0442\u0430\u043a\u0430"],"Term of Service":["\u0423\u0441\u043b\u043e\u0432\u0438 \u043a\u043e\u0440\u0438\u0448\u045b\u0435\u045a\u0430"],"Email address":["\u0410\u0434\u0440\u0435\u0441\u0430 \u0435-\u043f\u043e\u0448\u0442\u0435"],"This email will be used to create accounts with the selected plugin providers. Form protected by reCAPTCHA.":["\u041e\u0432\u0430 \u0435-\u043f\u043e\u0448\u0442\u0430 \u045b\u0435 \u0441\u0435 \u043a\u043e\u0440\u0438\u0441\u0442\u0438\u0442\u0438 \u0437\u0430 \u043a\u0440\u0435\u0438\u0440\u0430\u045a\u0435 \u043d\u0430\u043b\u043e\u0433\u0430 \u043a\u043e\u0434 \u043e\u0434\u0430\u0431\u0440\u0430\u043d\u0438\u0445 \u0434\u043e\u0431\u0430\u0432\u0459\u0430\u0447\u0430 \u0434\u043e\u0434\u0430\u0442\u0430\u043a\u0430. \u041e\u0431\u0440\u0430\u0437\u0430\u0446 \u0458\u0435 \u0437\u0430\u0448\u0442\u0438\u045b\u0435\u043d reCAPTCHA-\u043e\u043c."],"I agree to create accounts with the selected providers using my email address, and to their applicable Terms of Service.":["\u0421\u043b\u0430\u0436\u0435\u043c \u0441\u0435 \u0434\u0430 \u043d\u0430\u043f\u0440\u0430\u0432\u0438\u043c \u043d\u0430\u043b\u043e\u0433\u0435 \u043a\u043e\u0434 \u043e\u0434\u0430\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u0440\u043e\u0432\u0430\u0458\u0434\u0435\u0440\u0430 \u043a\u043e\u0440\u0438\u0441\u0442\u0435\u045b\u0438 \u0441\u0432\u043e\u0458\u0443 \u0430\u0434\u0440\u0435\u0441\u0443 \u0435-\u043f\u043e\u0448\u0442\u0435 \u0438 \u043f\u0440\u0438\u0445\u0432\u0430\u0442\u0430\u043c \u045a\u0438\u0445\u043e\u0432\u0435 \u0432\u0430\u0436\u0435\u045b\u0435 \u0443\u0441\u043b\u043e\u0432\u0435 \u043a\u043e\u0440\u0438\u0448\u045b\u0435\u045a\u0430."],"I wish to receive communications about news and\/or promotions from selected providers.":["\u0416\u0435\u043b\u0438\u043c \u0434\u0430 \u043f\u0440\u0438\u043c\u0430\u043c \u043e\u0431\u0430\u0432\u0435\u0448\u0442\u0435\u045a\u0430 \u043e \u0432\u0435\u0441\u0442\u0438\u043c\u0430 \u0438\/\u0438\u043b\u0438 \u043f\u0440\u043e\u043c\u043e\u0446\u0438\u0458\u0430\u043c\u0430 \u043e\u0434 \u043e\u0434\u0430\u0431\u0440\u0430\u043d\u0438\u0445 \u043f\u0440\u0443\u0436\u0430\u043b\u0430\u0446\u0430 \u0443\u0441\u043b\u0443\u0433\u0430."],"No thanks":["\u041d\u0435, \u0445\u0432\u0430\u043b\u0430"],"Create accounts":["\u041d\u0430\u043f\u0440\u0430\u0432\u0438 \u043d\u0430\u043b\u043e\u0433\u0435"]}}}